// okulin — PostgreSQL şeması (Redis KV göçü). Faz 0 taslağından onaylandı (2026-06-22).
// Çok-kiracılık: satır-düzeyi (orgSlug + branch kolonları, tenant-scoped client zorunlu kılar).
// Kimlik: surrogate cuid + legacyId (eski Redis id eşlemesi). Detay: docs/sql-sema-taslagi.prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_POSTGRES_PRISMA_URL")    // pooled — runtime sorguları
  directUrl = env("DATABASE_POSTGRES_URL_NON_POOLING") // direct — migration / db push
}

// ═══════════════════════ GLOBAL (tenant'sız) ═══════════════════════════════

model Org {
  slug       String   @id
  name       String
  active     Boolean  @default(true)
  type       String   @default("single")
  code       String?  @unique
  sektor     String   @default("dershane")
  mulkiyet   String   @default("ozel")
  kademeler  String[] @default([])
  shortName  String?
  logoUrl    String?
  themeColor String?
  createdAt  DateTime @default(now())
}

model SuperAdmin {
  id           String  @id @default(cuid())
  username     String  @unique
  passwordHash String
  // 2FA (SMS OTP, mevcut Twilio Verify altyapısı). null = 2FA kapalı — login normal akar.
  phone        String?
}

// Kurum şubeleri (org:<slug>:branches + org:<slug>:branch:<x> Redis karşılığı).
// GLOBAL (tenant-scope DEĞİL — şubeleri TANIMLAR). sqldb SKIP'te.
model Branch {
  id        String   @id @default(cuid())
  orgSlug   String
  slug      String   // 'main', 'akyazi', ...
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  @@unique([orgSlug, slug])
  @@index([orgSlug])
}

// Çok şubeli kurumun genel-merkez yöneticisi (orgadmin:<slug> Redis karşılığı). GLOBAL.
model OrgAdmin {
  id           String  @id @default(cuid())
  orgSlug      String  @unique
  username     String
  passwordHash String
  name         String?
}

// Landing'den gelen demo/iletişim talepleri (demo:requests Redis listesi). GLOBAL, kurum-bağımsız.
model DemoRequest {
  id        String   @id @default(cuid())
  name      String
  org       String?
  phone     String?
  email     String?
  note      String?
  ip        String?
  createdAt DateTime @default(now())
  @@index([createdAt])
}

model PayOrder {
  oid                 String    @id
  orgSlug             String
  branch              String    @default("main")
  studentId           String
  amount              Int
  status              String    @default("pending")
  processingToken     String?
  processingStartedAt DateTime?
  data                Json?
  createdAt           DateTime  @default(now())
  student             Student?  @relation(fields: [orgSlug, branch, studentId], references: [orgSlug, branch, legacyId], onDelete: Cascade)
  @@index([orgSlug, branch])
}

// ═══════════════════════ TENANT-KAPSAMLI ══════════════════════════════════

model Director {
  id           String @id @default(cuid())
  orgSlug      String
  branch       String @default("main")
  username     String
  passwordHash String
  name         String
  @@unique([orgSlug, branch])
}

model Counselor {
  id                 String  @id @default(cuid())
  orgSlug            String
  branch             String  @default("main")
  legacyId           String
  name               String
  username           String?
  passwordHash       String
  phone              String?
  mustChangePassword Boolean @default(true)
  @@unique([orgSlug, branch, legacyId])
}

// Müdür yardımcısı — müdürle BİREBİR aynı yetkiye sahip (login sonrası oturum
// role='director' + asst:true bayrağı taşır). Müdür oluşturur/siler. Çoklu olabilir.
// (Counselor/Accountant deseninin birebir eşi.)
model AssistantDirector {
  id                 String  @id @default(cuid())
  orgSlug            String
  branch             String  @default("main")
  legacyId           String
  name               String
  username           String?
  passwordHash       String
  phone              String?
  mustChangePassword Boolean @default(true)
  @@unique([orgSlug, branch, legacyId])
}

model Accountant {
  id                 String  @id @default(cuid())
  orgSlug            String
  branch             String  @default("main")
  legacyId           String
  name               String
  username           String?
  passwordHash       String
  phone              String?
  mustChangePassword Boolean @default(true)
  @@unique([orgSlug, branch, legacyId])
}

// Veli — TELEFON-BAZLI kimlik (phone = id/username). children = öğrencilerden
// türetilen snapshot [{id,name,cls}] (legacy id'ler). syncParents kurar/günceller.
model Parent {
  id                 String  @id @default(cuid())
  orgSlug            String
  branch             String  @default("main")
  phone              String
  passwordHash       String
  name               String?
  mustChangePassword Boolean @default(true)
  children           Json    @default("[]")
  @@unique([orgSlug, branch, phone])
  @@index([orgSlug, branch])
}

model Teacher {
  id                 String          @id @default(cuid())
  orgSlug            String
  branch             String          @default("main")
  legacyId           String
  name               String
  username           String
  passwordHash       String
  branches           String[]        @default([])
  allowedGroups      String[]        @default([])
  offDays            Int[]           @default([])
  photoUrl           String?
  phone              String?
  mustChangePassword Boolean         @default(true)
  programTemplate    Json?           // program:{legacyId} Redis objesi (grid şablonu + etutSablonlari)
  presets            TeacherPreset[]
  slotBookings       SlotBooking[]
  etutSablonlarRel   EtutSablon[]
  attendances        Attendance[]
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model TeacherPreset {
  id        String  @id @default(cuid())
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  classId   String
  course    String
}

model Student {
  id                 String    @id @default(cuid())
  orgSlug            String
  branch             String    @default("main")
  legacyId           String
  name               String
  username           String
  passwordHash       String
  class              Class?    @relation(fields: [classId], references: [id])
  classId            String?
  group              String
  phone              String?
  tcNo               String?   // öğrenci TC kimlik no (senet/makbuz — opsiyonel)
  birthDate          String?
  diplomaNotu        Float?    // yalnız mezun (50-100); OBP = ×5 türetilir
  mustChangePassword Boolean   @default(false)
  parentName         String?
  parentPhone        String?
  parentRelation     String?
  parentNote         String?
  parentTcNo         String?   // ödeyecek/veli TC kimlik no (senet — opsiyonel)
  parentAddress      String?   // veli/ödeyecek adresi (senet — opsiyonel)
  parent2Name        String?
  parent2Phone       String?
  parent2Relation    String?
  finance            Finance?
  behavior           Behavior?
  payOrders          PayOrder[]
  hedefler           Hedef[]
  topics             Topic[]
  guidances          Guidance[]
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
  @@index([classId])
}

model Class {
  id        String    @id @default(cuid())
  orgSlug   String
  branch    String    @default("main")
  legacyId  String
  ad        String
  group     String
  kademe    String
  duzey     String?
  dal       String?
  dersler   String[]  @default([])
  seeded    Boolean   @default(true)
  // Sınıf ders programı penceresi (KATI): { "0": [1,2,3], "5": [1,2] } — gün→ders NO listesi.
  // İşaretli slotlar CP-SAT'a windows olarak gider; işaretsiz güne/slota ders yerleşmez.
  slotTemplate Json?
  students  Student[]
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model Course {
  id      String  @id @default(cuid())
  orgSlug String
  branch  String  @default("main")
  key     String
  ad      String
  core    Boolean @default(true)
  family  String?
  active  Boolean @default(true)
  @@unique([orgSlug, branch, key])
  @@index([orgSlug, branch])
}

model SlotBooking {
  id          String  @id @default(cuid())
  orgSlug     String
  branch      String  @default("main")
  weekKey     String
  teacher     Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId   String
  dayIndex    Int
  slotId      String
  booked      Boolean @default(false)
  disabled    Boolean @default(false)
  fixed       Boolean @default(false)
  // Rezervasyon-dönemi kolonları (studentId/studentName/studentCls/dersBranch/bookedBy)
  // 2026-07-23'te düşürüldü — grid rezervasyonu B3'te emekli, canlı tarama 1560 satırda
  // hepsini boş/kopya kanıtladı. Etüt kimliği EtutReservation'da yaşar.
  data        Json?   // hücrenin tam içeriği (lessonType, cls, subBranch, branch)
  // Saat snapshot'ı (spec §4): slot saat config'i sonradan değişirse eski kayıt kaymasın.
  // Nullable — mevcut satırlar için boş; Faz 2 birleşik servis yazarken doldurur.
  startsAt    String?
  endsAt      String?
  @@unique([orgSlug, branch, weekKey, teacherId, dayIndex, slotId])
  @@index([orgSlug, branch, weekKey])
  @@index([orgSlug, branch, teacherId, weekKey])
}

model TenantConfig {
  orgSlug         String
  branch          String  @default("main")
  slotTimes       Json?
  currentWeek     String?
  programTemplate Json?
  receiptCounter  Int     @default(0)  // makbuz no sayacı (MKB-YYYY-#####)
  officialName    String? // kurum resmi ünvanı (senet/makbuz alacaklı — örn. "…Ltd. Şti.")
  taxOffice       String? // vergi dairesi
  taxNo           String? // vergi no
  officialAddress String? // kurum resmi adresi (belge üst/alt bilgisi)
  denemeNameMap   Json?   // deneme excelName(lower)→studentId kalıcı eşleştirme
  paymentConfig   Json?   // PayTR ödeme yapılandırması (payment:config Redis karşılığı; şifreli anahtarlar)
  @@id([orgSlug, branch])
}

// Kurum konfigürasyonu — "oyun ayarları" key-value store. TenantConfig'ten AYRI:
// TenantConfig operasyonel state tutar (slot saatleri, program şablonu, ödeme).
// OrgConfig kurumun TERCİH ayarlarını tutar (modül aç/kapa, etüt kuralları,
// rol yetkileri). Müdür Ayarlar > Konfigürasyon'dan yönetir. Eksik key = default davranış.
model OrgConfig {
  id      String @id @default(cuid())
  orgSlug String
  branch  String @default("main")
  key     String
  value   Json
  @@unique([orgSlug, branch, key])
  @@index([orgSlug, branch])
}

model Finance {
  id               String        @id @default(cuid())
  orgSlug          String
  branch           String        @default("main")
  student          Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId        String        @unique
  registrationDate String?
  // Para: Decimal(12,2) (Float→Decimal göçü 2026-07-23; okuma katmanı number'a çevirir — lib/prisma)
  totalFee         Decimal       @db.Decimal(12, 2)
  discount         Decimal       @default(0) @db.Decimal(12, 2)
  netFee           Decimal       @db.Decimal(12, 2)
  paymentPlan      String
  payments         Json?         // ödeme ledger'ı [{id,date,amount,method,note,receiptNo,recordedBy}]; balance türetilir
  installments     Installment[]
  @@index([orgSlug, branch])
}

model Installment {
  id         String  @id @default(cuid())
  finance    Finance @relation(fields: [financeId], references: [id], onDelete: Cascade)
  financeId  String
  idx        Int
  dueDate    String
  amount     Decimal @db.Decimal(12, 2)
  paid       Boolean @default(false)
  paidDate   String?
  paidAmount Decimal? @db.Decimal(12, 2)
  method     String?
  receiptNo  String?
}

model Expense {
  id       String @id @default(cuid())
  orgSlug  String
  branch   String @default("main")
  legacyId String
  type     String
  amount   Decimal @db.Decimal(12, 2)
  date     String
  data     Json?
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model Attendance {
  id        String  @id @default(cuid())
  orgSlug   String
  branch    String  @default("main")
  date      String  // YYYY-MM-DD
  teacher   Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  teacherId String
  cls       String  // sınıf kodu ("101", "m1" vb.)
  lessonNo  String  // "1","2",... veya "e<etutId>"
  records   Json    // { [studentId]: 'var' | 'gec' | 'yok' }
  @@unique([orgSlug, branch, date, teacherId, cls, lessonNo])
  @@index([orgSlug, branch])
  @@index([orgSlug, branch, date])
}

model Behavior {
  id        String          @id @default(cuid())
  orgSlug   String
  branch    String          @default("main")
  student   Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String          @unique
  total     Int             @default(0)
  entries   BehaviorEntry[]
  @@index([orgSlug, branch])
}

model BehaviorEntry {
  id         String   @id @default(cuid())
  behavior   Behavior @relation(fields: [behaviorId], references: [id], onDelete: Cascade)
  behaviorId String
  points     Int
  reason     String?
  note       String?
  byName     String?
  byRole     String?
  by         String?
  createdAt  DateTime @default(now())
}

model Exam {
  id             String    @id @default(cuid())
  orgSlug        String
  branch         String    @default("main")
  legacyId       String
  name           String
  examType       String
  category       String?
  date           String?
  kitapcikSayisi Int       @default(1)
  subjectKeys    String[]  @default([])
  answerKey      Json?
  computedAt     DateTime? // son yeniden-puanlama (compute route); report okur
  rows           ExamRow[]
  createdAt      DateTime  @default(now())
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model ExamRow {
  id        String  @id @default(cuid())
  exam      Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  examId    String
  studentId String?
  data      Json
}

// ── İkincil modüller (alanlar göç adımında netleşir; uzun kuyruk Json'da) ──

model Odev {
  id       String @id @default(cuid())
  orgSlug  String
  branch   String @default("main")
  legacyId String
  data     Json
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

// Haftalık soru-çözüm hedefi — öğrenci başına TEK kayıt (haftaya bağlı değil).
// "Çözülen soru" trendi guidance'tan türetilir; burada yalnız hedef sayısı tutulur.
model Hedef {
  id        String   @id @default(cuid())
  orgSlug   String
  branch    String   @default("main")
  studentId String   // legacy öğrenci id (route legacy id ile çalışır, join yok)
  weekly    Int      @default(0)
  setBy     String?
  setByName String?
  updatedAt DateTime @default(now())
  student   Student? @relation(fields: [orgSlug, branch, studentId], references: [orgSlug, branch, legacyId], onDelete: Cascade)
  @@unique([orgSlug, branch, studentId])
  @@index([orgSlug, branch])
}

model Etkinlik {
  id        String  @id @default(cuid())
  orgSlug   String
  branch    String  @default("main")
  legacyId  String
  title     String
  type      String
  startDate String
  endDate   String?
  data      Json
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model Form {
  id        String         @id @default(cuid())
  orgSlug   String
  branch    String         @default("main")
  legacyId  String
  data      Json
  responses FormResponse[]
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model FormResponse {
  id         String   @id @default(cuid())
  form       Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId     String
  respondent String?
  data       Json
  createdAt  DateTime @default(now())
}

model Lead {
  id       String @id @default(cuid())
  orgSlug  String
  branch   String @default("main")
  legacyId String
  name     String
  stage    String
  data     Json
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

// Duyuru — data = içerik (title/body/audience/audienceLabel/recipientCount/sender).
// Alıcılar + okundu durumu normalize (Redis announcement:<id>:reads + inbox fan-out
// yerine tek tablo). Inbox = recipients(role,recipientId) sorgusu; readCount = filtered _count.
model Announcement {
  id         String                  @id @default(cuid())
  orgSlug    String
  branch     String                  @default("main")
  legacyId   String
  data       Json
  createdAt  DateTime                @default(now())
  recipients AnnouncementRecipient[]
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

model AnnouncementRecipient {
  id             String       @id @default(cuid())
  orgSlug        String       // inbox sorgusu (role+recipientId) tenant-scope için ZORUNLU
  branch         String       @default("main")
  announcement   Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  announcementId String
  role           String
  recipientId    String
  name           String?
  read           Boolean      @default(false)
  @@index([orgSlug, branch, role, recipientId])
  @@index([announcementId])
}

model Resource {
  id       String  @id @default(cuid())
  orgSlug  String
  branch   String  @default("main")
  legacyId String
  title    String
  url      String?
  data     Json
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch])
}

// Konu/kazanım yüzdesi — öğrenci başına TEK kayıt (topics:<sid>).
// data = { [subject]: { [topicIndex]: percent 0-100 } }.
model Topic {
  id        String @id @default(cuid())
  orgSlug   String
  branch    String @default("main")
  studentId String   // legacy öğrenci id (route legacy id ile çalışır, join yok)
  data      Json
  student   Student? @relation(fields: [orgSlug, branch, studentId], references: [orgSlug, branch, legacyId], onDelete: Cascade)
  @@unique([orgSlug, branch, studentId])
  @@index([orgSlug, branch])
}

// Rehberlik soru-takibi — öğrenci+hafta bazlı (guidance:<sid>:<weekKey>).
// data = { entries:{[subject]:{correct,wrong,empty}}, reviewed, submittedAt, reviewedAt }.
model Guidance {
  id        String @id @default(cuid())
  orgSlug   String
  branch    String @default("main")
  studentId String   // legacy öğrenci id (route legacy id ile çalışır, join yok)
  week      String
  data      Json
  student   Student? @relation(fields: [orgSlug, branch, studentId], references: [orgSlug, branch, legacyId], onDelete: Cascade)
  @@unique([orgSlug, branch, studentId, week])
  @@index([orgSlug, branch])
  @@index([studentId])
}

model AuditLog {
  id      String   @id @default(cuid())
  orgSlug String
  branch  String   @default("main")
  at      DateTime @default(now())
  actor   String?
  action  String
  data    Json?
  @@index([orgSlug, branch])
}

model ErrLog {
  id      String   @id @default(cuid())
  orgSlug String
  branch  String   @default("main")
  at      DateTime @default(now())
  message String
  data    Json?
  @@index([orgSlug, branch])
}

// "Bir kez bildir" idempotency kaydı (Redis NX kilidinin SQL eşdeğeri).
// kind: 'att' (devamsızlık) | 'deneme' (deneme sonucu).
// dedupeKey: att → "<date>:<studentId>", deneme → "<examId>:<phone>".
// @@unique → aynı bildirim ikinci kez create edilince P2002 fırlatır = zaten bildirilmiş.
model NotifLog {
  id        String   @id @default(cuid())
  orgSlug   String
  branch    String   @default("main")
  kind      String
  dedupeKey String
  at        DateTime @default(now())
  @@unique([orgSlug, branch, kind, dedupeKey])
  @@index([orgSlug, branch])
}

model PushSub {
  id       String @id @default(cuid())
  orgSlug  String
  branch   String @default("main")
  role     String
  userId   String
  endpoint String @unique
  keys     Json
  @@index([orgSlug, branch])
}

// ── Bildirim outbox (kayıpsız teslimat) ─────────────────────────────────────
// NotificationEvent: kullanıcıya gösterilecek kalıcı bildirim kaydı (uygulama
// içi inbox bunu okuyacak) + outbox işlevi (dispatchStatus). Domain olayıyla
// aynı transaction'da yazılır → gönderim işi asla kaybolmaz.
// sensitive=true → push'ta jenerik metin (kilit ekranı mahremiyeti, Apple 4.5.4);
// tam title/body yalnız bu satırda (inbox'ta) durur.
model NotificationEvent {
  id             String    @id
  orgSlug        String
  branch         String    @default("main")
  role           String // student|teacher|parent|acc|cou|director
  userId         String // legacyId; parent için telefon (push.ts anahtarıyla birebir)
  title          String
  body           String
  url            String?
  tag            String?
  sensitive      Boolean   @default(false)
  data           Json?
  dispatchStatus String    @default("pending") // pending|done (delivery fan-out yazıldı)
  createdAt      DateTime  @default(now())
  readAt         DateTime?

  @@index([orgSlug, branch, role, userId, createdAt])
  @@index([dispatchStatus])
}

// Cihaz başına teslimat denemesi. target: webpush=endpoint / fcm=cihaz token'ı
// (denormalize — abonelik sonradan silinse de retry hedefini bilir).
model NotificationDelivery {
  id            String   @id
  eventId       String
  orgSlug       String
  branch        String   @default("main")
  provider      String // webpush|fcm
  target        String
  keys          Json? // yalnız webpush (p256dh/auth)
  status        String   @default("pending") // pending|sent|dead
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  providerId    String?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([eventId, target])
  @@index([status, nextAttemptAt])
  @@index([orgSlug, branch])
}

// Native uygulama kurulumları (FCM/APNs token kaydı). Mobil app (Plan 3)
// doldurur; bu planda yalnız fan-out okur (bugün boş döner).
model DeviceInstallation {
  id         String   @id // istemci üretimi rastgele installationId
  orgSlug    String
  branch     String   @default("main")
  platform   String // android|ios
  provider   String   @default("fcm") // fcm|apns
  token      String
  role       String
  userId     String
  appVersion String?
  enabled    Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@unique([provider, token])
  @@index([orgSlug, branch, role, userId])
}

// ── Mobil cihaz oturumları (/api/mobile/v1 token auth) ──────────────────────
// Refresh token DB'de yalnız sha256 hash olarak durur (düz token asla yazılmaz).
// Rotation: her refresh'te yeni token, eskisi prevRefreshHash'e kayar; grace (30sn)
// dışı prev kullanımı = REUSE → oturum revoke (lib/mobile/policy.ts durum makinesi).
// payload: access token claim'lerinin snapshot'ı — refresh'te yeniden imzalanır.
// revokedAt: logout/şifre değişimi/cihaz iptali → withMobileAuth her istekte kontrol eder.
model MobileSession {
  id              String    @id // ms_ önekli newId
  orgSlug         String
  branch          String    @default("main")
  role            String // oturum rolü (assistant_director → 'director', payload ile aynı)
  userId          String // legacyId; parent için telefon (web session.id ile birebir)
  payload         Json
  installationId  String? // istemci üretimi rastgele kurulum kimliği (reklam kimliği değil)
  deviceName      String?
  platform        String? // android|ios
  refreshHash     String    @unique
  prevRefreshHash String?
  rotatedAt       DateTime?
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime  @default(now())
  expiresAt       DateTime // kayan pencere: her rotation +60 gün
  revokedAt       DateTime?
  revokedReason   String? // reuse|çıkış|cihaz iptali|tüm cihazlardan çıkış|şifre değişti|şifre sıfırlandı
  createdIp       String?

  @@index([orgSlug, branch, role, userId])
  @@index([prevRefreshHash])
}

// Mobil uygulama GLOBAL konfigürasyonu — remote kill-switch (spec §9/3).
// Tek satır (id='default'); superadmin API'siyle güncellenir; bootstrap okur.
// GLOBAL tablo (kurum-bağımsız) → sqldb SKIP listesinde, base prisma ile erişilir.
model MobileAppConfig {
  id                  String   @id @default("default")
  minSupportedVersion String   @default("0.0.0")
  recommendedVersion  String   @default("0.0.0")
  maintenance         Boolean  @default(false)
  maintenanceMessage  String?
  flags               Json?
  updatedAt           DateTime @updatedAt
}

// Kullanıcı bazlı bildirim kategori tercihi (spec §5.1). Satır YOKSA = kategori AÇIK
// (varsayılan enabled). Yalnız SUSTURULAN kategoriler için satır olur (enabled=false).
// Kategori tag önekinden türetilir (lib/notify-prefs categoryOf) — NotificationEvent'te
// kategori alanı yok. guvenlik kategorisi burada saklanmaz (asla susturulamaz).
model NotificationPreference {
  id        String   @id @default(cuid())
  orgSlug   String
  branch    String   @default("main")
  role      String
  userId    String
  category  String
  enabled   Boolean  @default(true)
  updatedAt DateTime @updatedAt
  @@unique([orgSlug, branch, role, userId, category])
  @@index([orgSlug, branch, role, userId])
}

// ── Etüt şablonu (Faz 1 göçü: Teacher.programTemplate.etutSablonlari JSON → tablo) ──
// id = DB PK (cuid); legacyId = JSON'daki kimlik (API'ler etutId olarak bunu kullanır).
// Rezervasyon alanları BURADA DEĞİL — EtutReservation'da (hafta-bazlı).
model EtutSablon {
  id            String    @id @default(cuid())
  orgSlug       String
  branch        String    @default("main")
  legacyId      String    // JSON şablon id (etutSablonlari[].id) — API'ler etutId olarak bunu kullanır
  teacherId     String    // legacyId (etutSablonlari JSON konvansiyonu — DİKKAT: SlotBooking.teacherId bundan FARKLI, Teacher.id kullanır)
  teacher       Teacher   @relation(fields: [orgSlug, branch, teacherId], references: [orgSlug, branch, legacyId], onDelete: Cascade)
  dayIndex      Int
  start         String    // "HH:MM"
  end           String
  aktif         Boolean   @default(true)
  pasifHaftalar String[]  @default([])
  deletedAt     DateTime? // soft-delete (Faz 2: normal silme yolu bunu doldurur; cascade yalnız bilinçli hard-delete — reset-all)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  reservations  EtutReservation[]
  @@unique([orgSlug, branch, legacyId])
  @@index([orgSlug, branch, teacherId])
  @@index([orgSlug, branch])
}

enum EtutScope {
  WEEK
  RECURRING
}

enum EtutStatus {
  ACTIVE
  CANCELLED
}

// ── Hafta-bazlı etüt rezervasyonu (spec §3.2) ──
// scope=WEEK: weekKey gerçek hafta ("2026-W30"). scope=RECURRING: weekKey='*'
// (yalnız unique-marker) + effectiveFromWeek. WEEK satır recurring'i EZER;
// status=CANCELLED WEEK satırı = tombstone (o hafta boş). Soft-delete: fiziksel silme YOK.
model EtutReservation {
  id                String     @id @default(cuid())
  orgSlug           String
  branch            String     @default("main")
  sablonId          String
  sablon            EtutSablon @relation(fields: [sablonId], references: [id], onDelete: Cascade)
  teacherId         String     // legacyId — sorgu kolaylığı (denormalize)
  scope             EtutScope  // WEEK | RECURRING
  status            EtutStatus @default(ACTIVE) // ACTIVE | CANCELLED
  weekKey           String     // WEEK: "YYYY-Www" | RECURRING: "*"
  effectiveFromWeek String?    // yalnız RECURRING: bu haftadan itibaren
  studentId         String
  studentName       String
  studentCls        String
  dersBranch        String
  bookedByRole      String
  bookedById        String
  bookedAt          DateTime   @default(now())
  cancelledByRole   String?
  cancelledById     String?
  cancelledAt       DateTime?
  cancelReason      String?
  // Snapshot (geçmiş etiketi + interval çakışma; aktif doluluk sablonId+weekKey ile)
  dayIndex          Int
  startsAt          String     // "HH:MM"
  endsAt            String
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  @@unique([orgSlug, branch, sablonId, weekKey])
  @@index([orgSlug, branch, weekKey])
  @@index([orgSlug, branch, studentId, weekKey])
  @@index([orgSlug, branch, teacherId, weekKey])
  @@index([sablonId])
}
