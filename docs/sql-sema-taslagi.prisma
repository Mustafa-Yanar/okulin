// ───────────────────────────────────────────────────────────────────────────
// okulin — SQL Şema TASLAĞI (Faz 0, TARTIŞMA İÇİN — henüz gerçek prisma değil)
// Redis KV → PostgreSQL göçü. Canlı testkurs verisinden + koddan çıkarıldı (2026-06-22).
// Kararlar yorumlarda gerekçeleriyle. Onaylanınca prisma/schema.prisma'ya taşınır.
// ───────────────────────────────────────────────────────────────────────────

generator client { provider = "prisma-client-js" }
datasource db   { provider = "postgresql"; url = env("DATABASE_URL") }

// ── KARAR 1: Multi-tenancy = satır-düzeyi (row-level), tek DB ───────────────
// Redis'teki `t:<org>:<branch>:` prefix'inin birebir karşılığı. Her tenant-kapsamlı
// tablo `orgSlug` + `branch` taşır. Tüm sorgular bununla filtrelenir (Prisma extension/
// tenant-scoped client ile zorunlu kılınır — lib/db.js Proxy'sinin SQL hali). Neon-dostu,
// ucuz, tek DB. (DB-per-tenant ELENDI: ağır ops, free-tier'a uymaz.)
//
// ── KARAR 2: Kimlik = surrogate cuid + legacyId ─────────────────────────────
// Eski Redis id'leri ('m7','701', teacher ' 0b0xzji3') tenant İÇİNDE benzersiz. SQL PK
// surrogate `id` (cuid); `legacyId` göç eşlemesi + eski referansların korunması için.
// FK'ler surrogate üzerinden (gerçek ilişkisel bütünlük).
//
// ── KARAR 3: Normalize vs JSONB ─────────────────────────────────────────────
// Sorgu/rapor gereken iç içe yapılar NORMALIZE (installments, davranış entry, deneme satır).
// Gerçekten opak konfig/blob JSONB (slot_times, answerKey, program şablon grid'i).
//
// ── KARAR 4: Auth = role-bazlı ayrı tablolar (mevcut modelle aynı) ───────────
// Teacher/Student/Director/Counselor her biri kendi passwordHash'ini taşır (bugünkü gibi,
// göç yüzeyi küçük). Birleşik User tablosu "daha temiz" ama büyük refactor → ERTELENDİ.

// ═══════════════════════ GLOBAL (tenant'sız) ═══════════════════════════════

model Org {
  slug       String   @id                  // 'testkurs','cozum' — global benzersiz
  name       String
  active     Boolean  @default(true)
  type       String   @default("single")
  code       String?  @unique              // landing kurum kodu (orgcode:<CODE> yerine)
  // Kurum facet'leri (lib/institution.js) — eski kayıtta yoksa okuma-anı default'lanıyordu
  sektor     String   @default("dershane") // dershane | okul
  mulkiyet   String   @default("ozel")     // ozel | devlet
  kademeler  String[] @default([])         // ['ortaokul','lise','mezun']
  // Markalama (branding)
  shortName  String?
  logoUrl    String?
  themeColor String?
  createdAt  DateTime @default(now())
  branches   Branch[]
}

// org+branch çifti = tenant. Çoğu kurum tek 'main' şube; altyapı çok-şubeye hazır.
model Branch {
  id        String  @id @default(cuid())
  org       Org     @relation(fields: [orgSlug], references: [slug])
  orgSlug   String
  branch    String  @default("main")
  @@unique([orgSlug, branch])
}

model SuperAdmin {
  id           String @id @default(cuid())
  username     String @unique
  passwordHash String
}

// Ödeme siparişi (global — payorder:<oid>). PayTR callback eşleşmesi.
model PayOrder {
  oid       String   @id
  orgSlug   String
  branch    String   @default("main")
  studentId String
  amount    Int
  status    String   @default("pending")
  data      Json?    // sağlayıcı payload (BYO-keys, idempotent callback)
  createdAt DateTime @default(now())
}

// ═══════════════════════ TENANT-KAPSAMLI ══════════════════════════════════
// Konvansiyon: her tablo orgSlug + branch + (eski id için) legacyId taşır.
// @@unique([orgSlug, branch, legacyId]) göç eşlemesini ve tenant-içi benzersizliği sağlar.

model Director {
  id           String @id @default(cuid())
  orgSlug      String
  branch       String @default("main")
  username     String
  passwordHash String
  name         String
  @@unique([orgSlug, branch])            // kurum başına tek müdür
}

model Counselor {                          // rehber = müdür eksi muhasebe
  id           String  @id @default(cuid())
  orgSlug      String
  branch       String  @default("main")
  legacyId     String
  name         String
  username     String?
  passwordHash String
  phone        String?
  mustChangePassword Boolean @default(true)
  @@unique([orgSlug, branch, legacyId])
}

model Teacher {
  id           String   @id @default(cuid())
  orgSlug      String
  branch       String   @default("main")
  legacyId     String                       // eski teacher id ('0b0xzji3')
  name         String
  username     String
  passwordHash String
  branches     String[] @default([])         // ders adları (course key'leri) — KARAR: dizi mi FK mi? (aşağıda not)
  allowedGroups String[] @default([])        // ['lise','mezun']
  offDays      Int[]     @default([])
  photoUrl     String?
  phone        String?
  mustChangePassword Boolean @default(true)
  presets      TeacherPreset[]              // ön eşleştirme (sabit dersler)
  etutTemplates EtutTemplate[]
  slotBookings  SlotBooking[]
  @@unique([orgSlug, branch, legacyId])
}

// Ön eşleştirme: öğretmen→sınıf→ders kilidi (CP-SAT HARD preset). Eski teacher.presets[].
model TeacherPreset {
  id        String  @id @default(cuid())
  teacher   Teacher @relation(fields: [teacherId], references: [id])
  teacherId String
  classId   String                          // hedef şube (Class.id)
  course    String                          // ders key
}

model Student {
  id           String  @id @default(cuid())
  orgSlug      String
  branch       String  @default("main")
  legacyId     String                       // eski student id ('741zt9d5')
  name         String
  username     String
  passwordHash String
  class        Class?  @relation(fields: [classId], references: [id])
  classId      String?                       // eski student.cls → Class.id
  group        String                        // ortaokul|lise|mezun (köprü)
  phone        String?
  birthDate    String?
  mustChangePassword Boolean @default(false)
  // Veli (telefon-bazlı, salt-okunur parent paneli buradan türer — ayrı tablo değil)
  parentName     String?
  parentPhone    String?
  parentRelation String?
  parentNote     String?
  parent2Name    String?
  parent2Phone   String?
  parent2Relation String?
  finance      Finance?
  behavior     Behavior?
  @@unique([orgSlug, branch, legacyId])
}

// ── Şube/sınıf registry (lib/classes.js) ──
model Class {
  id        String   @id @default(cuid())
  orgSlug   String
  branch    String   @default("main")
  legacyId  String                          // eski cls kodu ('m7','701')
  ad        String                          // serbest etiket ('8-A','Einstein')
  group     String                          // köprü: ortaokul|lise|mezun
  kademe    String
  duzey     String?
  dal       String?                         // sayisal|ea|null
  dersler   String[] @default([])           // şubenin gördüğü ders key'leri (m2m alt-küme)
  seeded    Boolean  @default(true)
  students  Student[]
  @@unique([orgSlug, branch, legacyId])
}

// ── Ders kataloğu registry (lib/courses.js) ──
model Course {
  id       String  @id @default(cuid())
  orgSlug  String
  branch   String  @default("main")
  key      String                           // sabit anahtar/slug ('matematik','Biyoloji')
  ad       String
  core     Boolean @default(true)
  family   String?                          // 'matematik' (MATH_FAMILY etüt kuralı)
  active   Boolean @default(true)
  @@unique([orgSlug, branch, key])
}

// ── Etüt/program ──
// KARAR: program:<teacherId>.etutSablonlari[] → EtutTemplate (haftadan bağımsız tekrarlayan).
model EtutTemplate {
  id          String  @id @default(cuid())
  orgSlug     String
  branch      String  @default("main")
  teacher     Teacher @relation(fields: [teacherId], references: [id])
  teacherId   String
  dayIndex    Int
  start       String                         // '15:10'
  end         String
  aktif       Boolean @default(true)
  studentId   String?                        // atanan öğrenci (Student.id)
  bookedBy    String?                        // 'director'|'teacher'|'student'
}

// slot:<weekKey>:<teacherId>:<dayIdx>:<slotId> → o haftanın grid hücresi. (Redis'te TTL 16g;
// SQL'de expiresAt + periyodik temizlik VEYA sadece sakla — ucuz.)
model SlotBooking {
  id          String  @id @default(cuid())
  orgSlug     String
  branch      String  @default("main")
  weekKey     String                         // '2026-W23'
  teacher     Teacher @relation(fields: [teacherId], references: [id])
  teacherId   String
  dayIndex    Int
  slotId      String                         // 'w1','e3'
  booked      Boolean @default(false)
  disabled    Boolean @default(false)
  fixed       Boolean @default(false)
  studentId   String?
  studentName String?
  studentCls  String?
  branch_     String?                        // ders/branş (isim çakışması için _; gerçekte 'branch' alanı)
  bookedBy    String?
  @@unique([orgSlug, branch, weekKey, teacherId, dayIndex, slotId])
}

// CP-SAT program ŞABLONU (type:'available'|'ders'|'etut') + haftalık ayarlar JSONB.
// Bu yapı evrim geçirdi (etut-takvimi-calendar) → göçte mevcut kullanım netleştirilecek;
// şimdilik opak config olarak tenant'a bağlı tek kayıt.
model TenantConfig {
  orgSlug    String
  branch     String @default("main")
  slotTimes  Json?                           // {weekday[12],weekend[12],etutSuresi,molaSuresi}
  currentWeek String?
  programTemplate Json?                       // çözücü available/ders grid'i (evrilen yapı)
  @@id([orgSlug, branch])
}

// ── Finans (lib/finance.js) ──
model Finance {
  id           String  @id @default(cuid())
  orgSlug      String
  branch       String  @default("main")
  student      Student @relation(fields: [studentId], references: [id])
  studentId    String  @unique
  registrationDate String?
  totalFee     Float
  discount     Float   @default(0)
  netFee       Float
  paymentPlan  String                         // 'taksitli'|'pesin'
  installments Installment[]
}

model Installment {
  id         String  @id @default(cuid())
  finance    Finance @relation(fields: [financeId], references: [id])
  financeId  String
  idx        Int
  dueDate    String
  amount     Float
  paid       Boolean @default(false)
  paidDate   String?
  paidAmount Float?
  method     String?
  receiptNo  String?
}

model Expense {                                // kurum giderleri + personel maaş/ek ödeme
  id        String   @id @default(cuid())
  orgSlug   String
  branch    String   @default("main")
  legacyId  String
  type      String                            // gider türü / maaş / ek ödeme
  amount    Float
  date      String
  data      Json?                             // tür-özel alanlar (personel id, kategori vb.)
  @@unique([orgSlug, branch, legacyId])
}

// ── Akademik / aktivite ──
model Attendance {                             // yoklama (gün × sınıf)
  id        String @id @default(cuid())
  orgSlug   String
  branch    String @default("main")
  date      String
  classId   String
  records   Json                              // {studentId: 'var'|'yok'|'gec'...}
  @@unique([orgSlug, branch, date, classId])
}

model Behavior {                               // davranış puanlama (öğrenci-sahipli)
  id        String  @id @default(cuid())
  orgSlug   String
  branch    String  @default("main")
  student   Student @relation(fields: [studentId], references: [id])
  studentId String  @unique
  total     Int     @default(0)
  entries   BehaviorEntry[]
}
model BehaviorEntry {
  id         String   @id @default(cuid())
  behavior   Behavior @relation(fields: [behaviorId], references: [id])
  behaviorId String
  points     Int
  reason     String?
  by         String?
  createdAt  DateTime @default(now())
}

// Deneme sınavı (deneme:exam:<id>). rows = öğrenci optik satırları, answerKey = cevap anahtarı.
model Exam {
  id            String  @id @default(cuid())
  orgSlug       String
  branch        String  @default("main")
  legacyId      String
  name          String
  examType      String                          // TYT|AYT|LGS...
  category      String?
  date          String?
  kitapcikSayisi Int    @default(1)
  subjectKeys   String[] @default([])
  answerKey     Json?                            // {subject: 'ABCD...'} — opak
  rows          ExamRow[]
  createdAt     DateTime @default(now())
  @@unique([orgSlug, branch, legacyId])
}
model ExamRow {                                  // öğrenci başına optik/sonuç satırı
  id        String @id @default(cuid())
  exam      Exam   @relation(fields: [examId], references: [id])
  examId    String
  studentId String?
  data      Json                                 // D/Y/B, net, kazanım vb. (analiz alanları)
}

// ── İletişim / diğer modüller (ikincil — alanlar göç adımında netleşir) ──
// Ortak desen: id, orgSlug, branch, legacyId, + modüle özel alanlar + Json data (uzun kuyruk).
model Odev          { id String @id @default(cuid()) orgSlug String branch String @default("main") legacyId String data Json @@unique([orgSlug,branch,legacyId]) }
model Hedef         { id String @id @default(cuid()) orgSlug String branch String @default("main") studentId String week String data Json @@unique([orgSlug,branch,studentId,week]) }
model Etkinlik      { id String @id @default(cuid()) orgSlug String branch String @default("main") legacyId String title String type String startDate String endDate String? data Json @@unique([orgSlug,branch,legacyId]) }
model Form          { id String @id @default(cuid()) orgSlug String branch String @default("main") legacyId String data Json responses FormResponse[] @@unique([orgSlug,branch,legacyId]) }
model FormResponse  { id String @id @default(cuid()) form Form @relation(fields:[formId],references:[id]) formId String respondent String? data Json createdAt DateTime @default(now()) }
model Lead          { id String @id @default(cuid()) orgSlug String branch String @default("main") legacyId String name String stage String data Json @@unique([orgSlug,branch,legacyId]) } // ön kayıt/CRM
model Announcement  { id String @id @default(cuid()) orgSlug String branch String @default("main") legacyId String data Json createdAt DateTime @default(now()) @@unique([orgSlug,branch,legacyId]) }
model Resource      { id String @id @default(cuid()) orgSlug String branch String @default("main") legacyId String title String url String? data Json @@unique([orgSlug,branch,legacyId]) } // LMS kütüphane
model Guidance      { id String @id @default(cuid()) orgSlug String branch String @default("main") studentId String data Json } // rehberlik notları/haftalık takip
model AuditLog      { id String @id @default(cuid()) orgSlug String branch String @default("main") at DateTime @default(now()) actor String? action String data Json? }
model ErrLog        { id String @id @default(cuid()) orgSlug String branch String @default("main") at DateTime @default(now()) message String data Json? }
model PushSub       { id String @id @default(cuid()) orgSlug String branch String @default("main") role String userId String endpoint String @unique keys Json }
